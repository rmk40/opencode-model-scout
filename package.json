{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-model-scout",
  "version": "1.1.0",
  "description": "opencode plugin: auto-discover models from OpenAI-compatible providers, enrich with provider-specific metadata via probes",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:run",
    "fix": "npm run lint:fix && npm run format",
    "build": "npm run check"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "model-discovery",
    "openai-compatible",
    "ollama",
    "omlx"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmk40/opencode-model-scout.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.166"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.0.16"
  }
}
