{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-model-scout",
  "version": "1.1.0",
  "description": "opencode plugin: auto-discover models from OpenAI-compatible providers, enrich with provider-specific metadata via probes",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "build": "npm run typecheck && npm run test:run"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "model-discovery",
    "openai-compatible",
    "ollama",
    "omlx"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rmk40/opencode-model-scout.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.166"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
